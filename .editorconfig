[*.cs]
# Force IDE analysis to flag bad formatting immediately
dotnet_diagnostic.format.severity = warning

# 1. Define the camelCase style
dotnet_naming_style.camel_case_style.capitalization = camel_case

# 2. Define the symbol group for all methods
dotnet_naming_symbols.method_symbols.applicable_kinds = method
dotnet_naming_symbols.method_symbols.applicable_accessibilities = *

# 3. Create the rule and set the severity (suggestion, warning, or error)
dotnet_naming_rule.methods_should_be_camel_case.symbols = method_symbols
dotnet_naming_rule.methods_should_be_camel_case.style = camel_case_style
dotnet_naming_rule.methods_should_be_camel_case.severity = error

#### SYMBOL GROUPS ####
# Variables (Local variables and parameters)
dotnet_naming_symbols.variable_symbols.applicable_kinds = local, parameter

# Classes and Types
dotnet_naming_symbols.class_symbols.applicable_kinds = class, struct, interface, enum

# Methods
dotnet_naming_symbols.method_symbols.applicable_kinds = method
dotnet_naming_symbols.method_symbols.applicable_accessibilities = *


#### RULES (Set to warning) ####
# Enforce camelCase on methods
dotnet_naming_rule.methods_should_be_camel_case.symbols = method_symbols
dotnet_naming_rule.methods_should_be_camel_case.style = camel_case_style
dotnet_naming_rule.methods_should_be_camel_case.severity = error #warning

# Enforce camelCase on variables and parameters
dotnet_naming_rule.variables_should_be_camel_case.symbols = variable_symbols
dotnet_naming_rule.variables_should_be_camel_case.style = camel_case_style
dotnet_naming_rule.variables_should_be_camel_case.severity = error

# Enforce PascalCase on classes and types
dotnet_naming_rule.classes_should_be_pascal_case.symbols = class_symbols
dotnet_naming_rule.classes_should_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.classes_should_be_pascal_case.severity = error


#### 1. INDENTATION & TABS ####
# Standard indentation uses 4 spaces
indent_style = space
indent_size = 4
tab_width = 4

#### 2. BRACE PLACEMENT (K&R Style) ####
# Forces open braces to stay on the same line with a space before them
csharp_new_line_before_open_brace = none
csharp_space_before_open_brace_in_type_declaration = true

#### 3. SPACING (Style) ####
# Enforces a space after control flow keywords: 'if (x)' instead of 'if(x)'
csharp_space_after_keywords_in_control_flow_statements = true

# Spaces inside expressions and blocks
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
dotnet_space_around_binary_operators = before_and_after

#### 4. BLANK LINES & WRAPPING ####
# Keeps catch and else blocks on the same line as the closing brace: '} else {'
csharp_new_line_before_catch = false
csharp_new_line_before_else = false
csharp_new_line_before_finally = false

#### 5. CODE SEVERITY ####
# Tells Visual Studio to flag violations as warnings in the IDE
dotnet_diagnostic.format.severity = warning

# Prevent multiple consecutive blank lines
dotnet_style_allow_multiple_blank_lines_experimental = false
dotnet_diagnostic.IDE2000.severity = error

# 1. Global Web & ASPX Formatting Rules
# -------------------------------------------------------------
[*.{aspx,ascx,master,html}]
indent_style = space
indent_size = 4
tab_width = 4
trim_trailing_whitespace = true
insert_final_newline = true
